# HMAC secret for verifying requests from catChat
CATCHAT_EVENT_SECRET=replace-with-your-event-secret

# Incoming Webhook URL to post warning notifications to
CATCHAT_WEBHOOK_URL=http://localhost:8100/api/webhooks/1/your-token-here

# Comma-separated list of bad words to detect (case-insensitive)
BAD_WORDS=spam,badword,test

# Host and port for this bot server
HOST=0.0.0.0
PORT=9002
