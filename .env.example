# catChat Server environment example
# Copy to .env or run ./setup.sh to generate it automatically.
#
# Never commit .env. It contains CATCHAT_SERVER_SECRET.

# Display name shown in catChat Hub.
CATCHAT_SERVER_NAME=My catChat Server

# URL that catChat Hub and users can reach.
# localhost / 127.0.0.1 / 0.0.0.0 are not accepted as Public URL values.
CATCHAT_SERVER_PUBLIC_URL=https://your-server.example.com

# catChat Hub URL used to build the add-server invite link.
CATCHAT_HUB_URL=https://chat.dongurihub.com

# Private server secret. Generate with:
# openssl rand -hex 32
# Do not put this value in invite links, screenshots, or public docs.
CATCHAT_SERVER_SECRET=replace-with-openssl-rand-hex-32

# Startup invite code. This is safe to include in the add-server link.
CATCHAT_INVITE_CODE=INVITE-replace-with-random-code

# Host port mapped to the container's internal 8100 port.
CATCHAT_PORT=8100

# Registration token for catChat Hub. Required to generate common invite links.
# If you don't have a token, leave it blank (common invite link generation will be skipped).
CATCHAT_SERVER_REGISTRATION_TOKEN=

# Optional upload overrides can be placed in server.properties or as
# CATCHAT_SERVER_* environment variables. SVG uploads are always rejected.
